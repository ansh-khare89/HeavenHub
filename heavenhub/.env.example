# Render Deployment Environment Variables Template
# Copy this to Render Dashboard (Settings -> Environment Variables)

# Frontend URL (Used for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# Port (Render will automatically set this, but good to have)
PORT=8080

# Database Connection (Render provides DATABASE_URL natively, but you can override)
# It usually looks like: postgres://user:password@host:5432/dbname
DATABASE_URL=jdbc:postgresql://localhost:5432/heavenhub
DB_USER=postgres
DB_PASSWORD=your_secure_password

# Razorpay Keys (Get these from your Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
