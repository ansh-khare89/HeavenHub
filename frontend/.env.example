# ============================================
# API Configuration for HeavenHub Frontend
# ============================================

# Production backend URL (default: https://heavenhub-7hwn.onrender.com)
# Uncomment and change to override:
# VITE_API_URL=https://heavenhub-7hwn.onrender.com

# Development proxy target - where `npm run dev` proxies API requests
# Useful for local backend development (e.g., running Spring Boot locally)
# Default: uses VITE_API_URL or production URL
# VITE_DEV_PROXY_TARGET=http://localhost:8080

# ============================================
# Usage:
# - Development (local backend): Set VITE_API_URL and VITE_DEV_PROXY_TARGET to http://localhost:8080
# - Development (production backend): Leave commented, app uses https://heavenhub-7hwn.onrender.com
# - Production build: Leave commented, app uses https://heavenhub-7hwn.onrender.com
# ============================================
